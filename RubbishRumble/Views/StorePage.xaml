<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RubbishRumble.Views.StorePage"
             BackgroundColor="#FDCBB0"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20" RowSpacing="20">
        <!-- TOP HUD -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" VerticalOptions="Center">
            <Image Grid.Column="0" 
                   Source="store.png"
                   HeightRequest="50" 
                   WidthRequest="130"
                   Aspect="AspectFit"
                   HorizontalOptions="Start"
                   VerticalOptions="Center"/>

            <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                <!-- TOFIX: <Label Text="0" to Current value of players coins -->
                <Label Text="0" 
                       FontFamily="PixelifySans" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       TextColor="#4C3E24"
                       VerticalOptions="Center"/>
                <Image Source="coin.png" 
                       HeightRequest="30" 
                       WidthRequest="30"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Grid>

        <Grid Grid.Row="1" 
              RowDefinitions="*, *" 
              ColumnDefinitions="*, *" 
              RowSpacing="0" 
              ColumnSpacing="15">
            <!-- FREEZE Power Up -->
            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="15" VerticalOptions="Center">
                <Border Stroke="#4C3E24"
                        StrokeThickness="3"
                        StrokeShape="Rectangle"
                        Background="#9E4539"
                        Padding="20">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="15">
                        <!-- TOFIX: <Label Text="{Binding OwnedFreeze, StringFormat='Freeze&#10;({0})'}" -->
                        <!-- Basically, (3) is the number of times they have the freeze item -->
                        <Label Text="Freeze&#10;(3)" 
                                   FontFamily="PixelifySans"
                                   FontSize="18" 
                                   FontAttributes="Bold" 
                                   TextColor="#FDCBB0" 
                                   HorizontalTextAlignment="Center"/>

                        <Image Source="freeze01.png" 
                               HeightRequest="60" 
                               WidthRequest="60" 
                               Aspect="AspectFit"/>
                        <Label Text="Coins: 15" 
                               FontFamily="PixelifySans" 
                               FontSize="18" 
                               FontAttributes="Bold"
                               TextColor="#FDCBB0" 
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
                <!-- TOFIX: Command="{Binding BuyFreezeCommand}}" -->
                <ImageButton Source="buy.png"  
                             BackgroundColor="#9E4539"
                             BorderColor="#4C3E24"
                             BorderWidth="3"
                             Aspect="AspectFit"
                             Padding="5"
                             WidthRequest="100"
                             HeightRequest="45"
                             HorizontalOptions="Center"
                             Command="{Binding BuyFreezeCommand}"/>
            </VerticalStackLayout>
            <!-- SLOW Power Up -->
            <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="15" VerticalOptions="Center">
                <Border Stroke="#4C3E24"
                        StrokeThickness="3"
                        StrokeShape="Rectangle"
                        Background="#9E4539"
                        Padding="20">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="15">
                        <!-- TOFIX: <Label Text="{Binding OwnedSlow, StringFormat='Slow&#10;({0})'}" -->
                        <Label Text="Slow&#10;(3)" 
                                   FontFamily="PixelifySans"
                                   FontSize="18" 
                                   FontAttributes="Bold" 
                                   TextColor="#FDCBB0" 
                                   HorizontalTextAlignment="Center"/>

                        <Image Source="slow01.png" 
                               HeightRequest="60" 
                               WidthRequest="60" 
                               Aspect="AspectFit"/>

                        <Label Text="Coins: 15" 
                               FontFamily="PixelifySans" 
                               FontSize="18" 
                               FontAttributes="Bold"
                               TextColor="#FDCBB0" 
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
                <!-- TOFIX: Command="{Binding BuySlowCommand}}" -->
                <ImageButton Source="buy.png"  
                             BackgroundColor="#9E4539"
                             BorderColor="#4C3E24"
                             BorderWidth="3"
                             Aspect="AspectFit"
                             Padding="5"
                             WidthRequest="100"
                             HeightRequest="45"
                             HorizontalOptions="Center"
                             Command="{Binding BuySlowCommand}"/>
            </VerticalStackLayout>
            <!-- AUTO SORT Power Up -->
            <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="15" VerticalOptions="Center">
                <Border Stroke="#4C3E24"
                        StrokeThickness="3"
                        StrokeShape="Rectangle"
                        Background="#9E4539"
                        Padding="20">

                    <VerticalStackLayout HorizontalOptions="Center" Spacing="15">
                        <!-- TOFIX: <Label Text="{Binding OwnedAutoSort, StringFormat='AutoSort&#10;({0})'}" -->
                        <Label Text="Auto Sort&#10;(3)" 
                               FontFamily="PixelifySans"
                               FontSize="18" 
                               FontAttributes="Bold" 
                               TextColor="#FDCBB0" 
                               HorizontalTextAlignment="Center"/>

                        <Image Source="autosort01.png" 
                               HeightRequest="60" 
                               WidthRequest="60" 
                               Aspect="AspectFit"/>

                        <Label Text="Coins: 50" 
                               FontFamily="PixelifySans" 
                               FontSize="18" 
                               FontAttributes="Bold"
                               TextColor="#FDCBB0" 
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
                <!-- TOFIX: Command="{Binding BuyAutoSortCommand}}" -->
                <ImageButton Source="buy.png"  
                             BackgroundColor="#9E4539"
                             BorderColor="#4C3E24"
                             BorderWidth="3"
                             Aspect="AspectFit"
                             Padding="5"
                             WidthRequest="100"
                             HeightRequest="45"
                             HorizontalOptions="Center"
                             Command="{Binding BuyAutoSortCommand}"/>
            </VerticalStackLayout>
            <!-- SPEED Power Up -->
            <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="15" VerticalOptions="Center">
                <Border Stroke="#4C3E24"
                        StrokeThickness="3"
                        StrokeShape="Rectangle"
                        Background="#9E4539"
                        Padding="20">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="15">
                        <!-- TOFIX: <Label Text="{Binding OwnedSpeed, StringFormat='Speed&#10;({0})'}" -->
                        <Label Text="Speed&#10;(3)" 
                                   FontFamily="PixelifySans"
                                   FontSize="18" 
                                   FontAttributes="Bold" 
                                   TextColor="#FDCBB0" 
                                   HorizontalTextAlignment="Center"/>

                        <Image Source="speed01.png" 
                               HeightRequest="60" 
                               WidthRequest="60" 
                               Aspect="AspectFit"/>

                        <Label Text="Coins: 10" 
                               FontFamily="PixelifySans" 
                               FontSize="18" 
                               FontAttributes="Bold"
                               TextColor="#FDCBB0" 
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
                <!-- TOFIX: Command="{Binding BuySpeedCommand}}" -->
                <ImageButton Source="buy.png"  
                             BackgroundColor="#9E4539"
                             BorderColor="#4C3E24"
                             BorderWidth="3"
                             Aspect="AspectFit"
                             Padding="5"
                             WidthRequest="100"
                             HeightRequest="45"
                             HorizontalOptions="Center"
                             Command="{Binding BuySpeedCommand}"/>
            </VerticalStackLayout>
        </Grid>

        <ImageButton Grid.Row="2"
                     Source="exit.png"  
                     BackgroundColor="#9E4539"
                     BorderColor="#4C3E24"
                     BorderWidth="3"
                     Aspect="AspectFit"
                     Padding="5"
                     WidthRequest="160"
                     HeightRequest="50"
                     Margin="0,0,0,25"
                     HorizontalOptions="Center"
                     Clicked="OnExitButtonClicked"/>
    </Grid>
</ContentPage>