<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ViewModels="clr-namespace:RubbishRumble.ViewModels"
             xmlns:Models="clr-namespace:RubbishRumble.ViewModels"
             x:Class="RubbishRumble.Views.LeaderboardPage"
             x:DataType="ViewModels:LeaderboardViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FDCBB0">
    <Grid>
        <Image Source="mainbg.png"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill" />

        <Grid RowDefinitions="*, Auto, *" Padding="30" RowSpacing="20">
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" VerticalOptions="Center">
                <Image Grid.Column="0" 
                       Source="leaderboard_title.png"
                       HeightRequest="45" 
                       Aspect="AspectFit"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Grid>

            <VerticalStackLayout Grid.Row="1" Spacing="15" HorizontalOptions="Center" MaximumWidthRequest="340">
                <Border Stroke="#4C3E24"
                        StrokeThickness="3"
                        StrokeShape="Rectangle"
                        Background="#9E4539"
                        Padding="12">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="HIGH SCORES"
                               FontSize="16"
                               FontFamily="PixelifySans"
                               FontAttributes="Bold"
                               TextColor="#FDCBB0"
                               HorizontalTextAlignment="Center"/>

                        <ScrollView HeightRequest="280" VerticalScrollBarVisibility="Always">
                            <CollectionView ItemsSource="{Binding SavedProfiles}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="Models:UserProfileModel">
                                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12" Padding="5,8" VerticalOptions="Center">
                                            <Image Grid.Column="0" 
                                                   Source="{Binding AvatarImage}" 
                                                   HeightRequest="30" 
                                                   WidthRequest="30"
                                                   VerticalOptions="Center"/>

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="2"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding Name}" 
                                                       TextColor="#FDCBB0" 
                                                       FontFamily="PixelifySans" 
                                                       FontSize="14" 
                                                       LineBreakMode="TailTruncation"/>
                                                <Label Text="{Binding PlayedDate}" 
                                                       TextColor="#E8B8A8" 
                                                       FontFamily="PixelifySans" 
                                                       FontSize="11"/>
                                            </VerticalStackLayout>

                                            <Label Grid.Column="2" 
                                                   Text="{Binding HighScore}" 
                                                   TextColor="#FDCBB0" 
                                                   FontFamily="PixelifySans" 
                                                   FontSize="14" 
                                                   FontAttributes="Bold" 
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </ScrollView>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <ImageButton Grid.Row="2"
                         Source="exit.png"  
                         BackgroundColor="#9E4539"
                         BorderColor="#4C3E24"
                         BorderWidth="3"
                         Aspect="AspectFit"
                         Padding="5"
                         WidthRequest="160"
                         HeightRequest="50"
                         Margin="0,0,0,25"
                         HorizontalOptions="Center"
                         Clicked="OnExitButtonClicked"/>
        </Grid>
    </Grid>
</ContentPage>
