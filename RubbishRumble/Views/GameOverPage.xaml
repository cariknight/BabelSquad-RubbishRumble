<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ViewModels="clr-namespace:RubbishRumble.ViewModels"
             x:Class="RubbishRumble.Views.GameOverPage"
             x:DataType="ViewModels:GameOverViewModel"
             BackgroundColor="#FDCBB0"
             Shell.NavBarIsVisible="False">
    
    <Grid VerticalOptions="Center">
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="50" WidthRequest="300">
            <Image Source="gameover.png"
                   HeightRequest="100"
                   Aspect="AspectFit"
                   HorizontalOptions="Center"/>

            <Border Stroke="#4C3E24"
                    StrokeThickness="3"
                    StrokeShape="Rectangle"
                    BackgroundColor="#9E4539"
                    Padding="20"
                    Margin="0,10,0,10">

                <VerticalStackLayout Spacing="0">
                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                        <Label Text="TOTAL SCORE:"
                       FontSize="22"
                       FontFamily="PixelifySans"
                       FontAttributes="Bold"
                       TextColor="#FDCBB0"
                       HorizontalTextAlignment="Center"/>
                        <Label Text="{Binding TotalScore}"
                       FontSize="30"
                       FontFamily="PixelifySans"
                       FontAttributes="Bold"
                       TextColor="#FDCBB0"
                       HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                        <Image Source="coin.png"
                               HeightRequest="30"
                               WidthRequest="30"
                               Aspect="AspectFit"
                               VerticalOptions="Center"/>

                        <Label Text="{Binding EarnedCoins}"
                               FontSize="30"
                               FontFamily="PixelifySans"
                               FontAttributes="Bold"
                               TextColor="#FDCBB0"
                               VerticalOptions="Center"
                               HorizontalTextAlignment="Start"/>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

            <ImageButton Source="exit.png"
                         Command="{Binding ExitCommand}"
                         BackgroundColor="#9E4539"
                         BorderColor="#4C3E24"
                         BorderWidth="3"
                         Padding="5"
                         Aspect="AspectFit"
                         HeightRequest="50"
                         WidthRequest="160"
                         HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>